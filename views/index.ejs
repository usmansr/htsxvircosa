                    { label: 'Tools', value: 'Jenkins, Apache Tomcat' }
                ],
                links: [
                    { type: 'secondary', url: 'https://drive.google.com/drive/folders/1GqEOuI3HNT9IvpZs-VADNjjiapIsPOm4?usp=drive_link', icon: 'fa-folder-open', text: 'View Docs' }
