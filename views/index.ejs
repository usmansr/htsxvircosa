                    </div>
                    <div class="modal-links">
                        ${data.links.map(l => `<a href="${l.url}" target="_blank" class="modal-link ${l.type}"><i class="fas ${l.icon}"></i> ${l.text}</a>`).join('')}
                    </div>
                </div>
            `;
            document.getElementById('projectModal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        function closeModal() {
            document.getElementById('projectModal').classList.remove('active');
            document.body.style.overflow = '';
        }
        document.getElementById('projectModal').addEventListener('click', (e) => { if (e.target.id === 'projectModal') closeModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeModal(); closePie(); } });

        // Smooth scroll
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });

        // Mobile menu toggle
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        let mobileMenuOpen = false;
        mobileMenuBtn.addEventListener('click', () => {
            mobileMenuOpen = !mobileMenuOpen;
            const links = document.querySelector('.nav-links');
            if (links) {
                links.classList.toggle('hidden');
                links.classList.toggle('flex');
                links.classList.toggle('flex-col');
                links.classList.toggle('absolute');
                links.classList.toggle('top-full');
                links.classList.toggle('left-0');
                links.classList.toggle('right-0');
                links.classList.toggle('bg-white');
                links.classList.toggle('p-4');
                links.classList.toggle('rounded-2xl');
                links.classList.toggle('shadow-xl');
                links.classList.toggle('mt-2');
            }
        });
    </script>
</body>
</html>