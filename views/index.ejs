<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usman Sarwar | MERN Stack Developer & DevOps Enthusiast</title>
    <meta name="description" content="Portfolio of Usman Sarwar — MERN Stack Developer, DevOps Enthusiast, and Computer Science student at UMT Lahore.">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#F8F5F2',
                            100: '#E8DDD4',
                            200: '#D4AF8E',
                            300: '#C49A6C',
                            400: '#A67C52',
                            500: '#8B5A2B',
                            600: '#6B4423',
                            700: '#4A2C2A',
                            800: '#2A2118',
                            900: '#1A1512',
                        }
                    },
                    fontFamily: {
                        serif: ['Playfair Display', 'serif'],
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>

    <style>
        :root {
            --nav-primary: #8B5A2B;
            --nav-secondary: #4A2C2A;
            --nav-accent: #D4AF8E;
            --nav-light: #F8F5F2;
            --nav-dark: #2A2118;
            --glass-bg: rgba(255, 255, 255, 0.85);
            --glass-border: rgba(255, 255, 255, 0.3);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--nav-light);
            color: var(--nav-dark);
            overflow-x: hidden;
            cursor: none;
        }

        /* Custom Cursor */
        .cursor-dot, .cursor-outline {
            position: fixed; top: 0; left: 0;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            z-index: 99999;
            pointer-events: none;
        }
        .cursor-dot { width: 8px; height: 8px; background: var(--nav-primary); transition: width 0.2s, height 0.2s, background 0.2s; }
        .cursor-outline { width: 40px; height: 40px; border: 2px solid var(--nav-accent); transition: width 0.3s, height 0.3s, border-color 0.3s, opacity 0.3s; opacity: 0.5; }
        body:hover .cursor-outline { opacity: 0.5; }
        .cursor-hover .cursor-dot { width: 12px; height: 12px; background: var(--nav-secondary); }
        .cursor-hover .cursor-outline { width: 60px; height: 60px; border-color: var(--nav-primary); opacity: 0.8; background: rgba(139, 90, 43, 0.05); }
        @media (pointer: coarse) { .cursor-dot, .cursor-outline { display: none; } body { cursor: auto; } }

        /* Navbar */
        .navbar {
            position: fixed; top: 16px; left: 50%; transform: translateX(-50%);
            width: calc(100% - 40px); max-width: 1400px; z-index: 1000;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 24px; padding: 12px 24px;
            box-shadow: 0 8px 32px rgba(139, 90, 43, 0.08);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .navbar.scrolled { top: 12px; width: calc(100% - 24px); padding: 10px 20px; box-shadow: 0 12px 48px rgba(139, 90, 43, 0.15); }
        .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--nav-secondary); text-decoration: none; display: flex; align-items: center; gap: 8px; }
        .nav-logo span { background: linear-gradient(135deg, var(--nav-primary), var(--nav-accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .nav-link { position: relative; padding: 8px 16px; border-radius: 12px; color: var(--nav-dark); font-weight: 500; font-size: 0.95rem; text-decoration: none; transition: all 0.3s ease; overflow: hidden; }
        .nav-link::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(139,90,43,0.08), rgba(212,175,142,0.08)); border-radius: 12px; transform: scaleX(0); transform-origin: right; transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1); z-index: -1; }
        .nav-link:hover::before, .nav-link.active::before { transform: scaleX(1); transform-origin: left; }
        .nav-link:hover { color: var(--nav-primary); }
        .nav-cta { background: linear-gradient(135deg, var(--nav-primary), #A67C52); color: white; padding: 10px 24px; border-radius: 50px; font-weight: 600; font-size: 0.9rem; border: none; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(139, 90, 43, 0.3); position: relative; overflow: hidden; }
        .nav-cta::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); transition: left 0.6s; }
        .nav-cta:hover::before { left: 100%; }
        .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(139, 90, 43, 0.4); }
        .mobile-menu-btn { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 8px; }
        .mobile-menu-btn span { display: block; width: 24px; height: 2px; background: var(--nav-primary); border-radius: 2px; transition: all 0.3s ease; }
        @media (max-width: 768px) { .mobile-menu-btn { display: flex; } .nav-links { display: none; } .navbar { padding: 10px 16px; } }

        /* Hero */
        .hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; background: linear-gradient(135deg, #1a1512 0%, #2A2118 50%, #1a1512 100%); overflow: hidden; }
        #particle-canvas { position: absolute; inset: 0; z-index: 1; }
        .hero-content { position: relative; z-index: 2; text-align: center; padding: 0 20px; max-width: 900px; }
        .hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 20px; background: rgba(212, 175, 142, 0.1); border: 1px solid rgba(212, 175, 142, 0.3); border-radius: 50px; color: var(--nav-accent); font-size: 0.9rem; font-weight: 500; margin-bottom: 32px; margin-top: 90px; animation: fadeInDown 1s ease-out; }
        .hero-badge .pulse { width: 8px; height: 8px; background: #4ade80; border-radius: 50%; animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
        .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 900; color: white; line-height: 1.1; margin-bottom: 24px; letter-spacing: -0.02em; }
        .hero h1 .gradient-text { background: linear-gradient(135deg, var(--nav-accent), #E6C9A8, var(--nav-primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-size: 200% auto; animation: shine 3s linear infinite; }
        @keyframes shine { to { background-position: 200% center; } }
        .hero-subtitle { font-size: clamp(1.1rem, 2vw, 1.4rem); color: rgba(255,255,255,0.7); font-weight: 300; margin-bottom: 40px; line-height: 1.6; max-width: 600px; margin-left: auto; margin-right: auto; }
        .hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
        .btn-primary { background: linear-gradient(135deg, var(--nav-primary), #A67C52); color: white; padding: 16px 40px; border-radius: 50px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 8px 30px rgba(139, 90, 43, 0.4); border: none; position: relative; overflow: hidden; }
        .btn-primary::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); transition: left 0.6s; }
        .btn-primary:hover::before { left: 100%; }
        .btn-primary:hover { transform: translateY(-4px); box-shadow: 0 15px 40px rgba(139, 90, 43, 0.5); }
        .btn-secondary { background: rgba(255,255,255,0.05); color: white; padding: 16px 40px; border-radius: 50px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 10px; transition: all 0.4s ease; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(10px); }
        .btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: var(--nav-accent); transform: translateY(-4px); }
        .hero-stats { display: flex; justify-content: center; gap: 48px; margin-top: 64px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,0.1); animation: fadeInUp 1.2s ease-out 0.5s both; }
        .stat-item h3 { font-family: 'Playfair Display', serif; font-size: 2.5rem; color: var(--nav-accent); font-weight: 700; }
        .stat-item p { color: rgba(255,255,255,0.6); font-size: 0.9rem; margin-top: 4px; }
        @media (max-width: 640px) { .hero-stats { gap: 24px; } .stat-item h3 { font-size: 1.8rem; } }

        /* Section Utils */
        .section-padding { padding: 120px 20px; }
        .section-header { text-align: center; max-width: 700px; margin: 0 auto 80px; }
        .section-header h2 { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 3rem); color: var(--nav-secondary); margin-bottom: 16px; font-weight: 700; }
        .section-header p { color: #666; font-size: 1.1rem; line-height: 1.7; }
        .section-tag { display: inline-block; padding: 6px 16px; background: rgba(139, 90, 43, 0.08); color: var(--nav-primary); border-radius: 50px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }

        /* Services / Skills Cards */
        .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; max-width: 1200px; margin: 0 auto; }
        .service-card { background: white; border-radius: 24px; padding: 40px 32px; border: 1px solid rgba(139, 90, 43, 0.08); box-shadow: 0 4px 20px rgba(0,0,0,0.04); transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); position: relative; overflow: hidden; transform-style: preserve-3d; perspective: 1000px; }
        .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--nav-primary), var(--nav-accent)); transform: scaleX(0); transition: transform 0.5s ease; }
        .service-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(139, 90, 43, 0.12); }
        .service-card:hover::before { transform: scaleX(1); }
        .service-icon { width: 64px; height: 64px; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 24px; background: linear-gradient(135deg, rgba(139,90,43,0.1), rgba(212,175,142,0.1)); color: var(--nav-primary); transition: all 0.4s ease; }
        .service-card:hover .service-icon { transform: scale(1.1) rotate(-5deg); background: linear-gradient(135deg, var(--nav-primary), var(--nav-accent)); color: white; }
        .service-card h3 { font-size: 1.25rem; font-weight: 700; color: var(--nav-secondary); margin-bottom: 12px; }
        .service-card p { color: #666; font-size: 0.95rem; line-height: 1.7; }
        .service-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
        .service-tag { padding: 4px 12px; background: var(--nav-light); color: var(--nav-primary); border-radius: 20px; font-size: 0.8rem; font-weight: 500; border: 1px solid rgba(139,90,43,0.1); }

        /* Bento Grid */
        .bento-grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 280px; gap: 20px; max-width: 1200px; margin: 0 auto; }
        .bento-item { background: white; border-radius: 24px; overflow: hidden; position: relative; border: 1px solid rgba(139, 90, 43, 0.08); box-shadow: 0 4px 20px rgba(0,0,0,0.04); transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
        .bento-item:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 20px 60px rgba(139, 90, 43, 0.15); z-index: 2; }
        .bento-item .bento-bg { position: absolute; inset: 0; background: linear-gradient(135deg, var(--nav-secondary), var(--nav-primary)); opacity: 0.95; transition: all 0.5s ease; overflow: hidden; }
        .bento-item .bento-bg img { width: 100%; height: 100%; object-fit: cover; transition: all 0.5s ease; filter: brightness(0.7) contrast(1.1); }
        .bento-item:hover .bento-bg { opacity: 1; }
        .bento-item:hover .bento-bg img { filter: brightness(0.85) contrast(1.15) scale(1.05); }
        .bento-item .bento-bg::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at top right, rgba(139, 90, 43, 0.3), rgba(0, 0, 0, 0.5)); z-index: 1; }
        .bento-item .bento-content { position: absolute; inset: 0; padding: 32px; display: flex; flex-direction: column; justify-content: flex-end; z-index: 2; color: white; }
        .bento-item .bento-content h3 { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; margin-bottom: 8px; }
        .bento-item .bento-content p { font-size: 0.9rem; opacity: 0.85; line-height: 1.6; margin-bottom: 16px; }
        .bento-item .bento-tags { display: flex; gap: 8px; flex-wrap: wrap; }
        .bento-item .bento-tags span { padding: 4px 12px; background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); border-radius: 20px; font-size: 0.75rem; font-weight: 500; border: 1px solid rgba(255,255,255,0.1); }
        .bento-item .bento-icon { position: absolute; top: 24px; right: 24px; width: 48px; height: 48px; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; border: 1px solid rgba(255,255,255,0.15); transition: all 0.4s ease; }
        .bento-item:hover .bento-icon { transform: rotate(15deg) scale(1.1); background: rgba(255,255,255,0.2); }
        .bento-item:nth-child(1) { grid-column: span 2; grid-row: span 2; }
        .bento-item:nth-child(2) { grid-column: span 2; }
        .bento-item:nth-child(3) { grid-column: span 1; grid-row: span 2; }
        .bento-item:nth-child(4) { grid-column: span 1; grid-row: span 2; }
        .bento-item:nth-child(5) { grid-column: span 2; }
        @media (max-width: 1024px) { .bento-grid { grid-template-columns: repeat(2, 1fr); } .bento-item:nth-child(1) { grid-column: span 2; grid-row: span 2; } .bento-item:nth-child(2) { grid-column: span 2; } .bento-item:nth-child(3) { grid-column: span 1; grid-row: span 1; } .bento-item:nth-child(4) { grid-column: span 1; } .bento-item:nth-child(5) { grid-column: span 2; } }
        @media (max-width: 640px) { .bento-grid { grid-template-columns: 1fr; grid-auto-rows: 240px; } .bento-item:nth-child(n) { grid-column: span 1; grid-row: span 1; } }
        .bento-item:nth-child(1) .bento-bg { background: linear-gradient(135deg, #2A2118, #4A2C2A); }
        .bento-item:nth-child(2) .bento-bg { background: linear-gradient(135deg, #1a365d, #2c5282); }
        .bento-item:nth-child(3) .bento-bg { background: linear-gradient(135deg, #744210, #975a16); }
        .bento-item:nth-child(4) .bento-bg { background: linear-gradient(135deg, #276749, #2f855a); }
        .bento-item:nth-child(5) .bento-bg { background: linear-gradient(135deg, #702459, #97266d); }

        /* Carousel */
        .carousel-container { position: relative; max-width: 1200px; margin: 0 auto; overflow: hidden; border-radius: 32px; }
        .carousel-track { display: flex; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
        .carousel-slide { min-width: 100%; padding: 0 10px; }
        .carousel-card { background: white; border-radius: 24px; overflow: hidden; display: grid; grid-template-columns: 1fr 1fr; min-height: 450px; border: 1px solid rgba(139, 90, 43, 0.08); box-shadow: 0 10px 40px rgba(0,0,0,0.06); }
        .carousel-visual { background: linear-gradient(135deg, var(--nav-secondary), var(--nav-primary)); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; padding: 40px; min-height: 300px; }
        .carousel-visual img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; filter: brightness(0.7) contrast(1.1); transition: all 0.5s ease; }
        .carousel-slide:hover .carousel-visual img { filter: brightness(0.85) contrast(1.15) scale(1.05); }
        .carousel-visual::before { content: ''; position: absolute; width: 200%; height: 200%; background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 20px 20px; opacity: 0.3; z-index: 2; }
        .carousel-visual::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at top right, rgba(139, 90, 43, 0.3), rgba(0, 0, 0, 0.5)); z-index: 3; }
        .carousel-visual i { font-size: 6rem; color: rgba(255,255,255,0.2); position: relative; z-index: 4; }
        .carousel-info { padding: 48px; display: flex; flex-direction: column; justify-content: center; }
        .carousel-info .project-tag { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; background: rgba(139, 90, 43, 0.08); color: var(--nav-primary); border-radius: 50px; font-size: 0.8rem; font-weight: 600; width: fit-content; margin-bottom: 20px; }
        .carousel-info h3 { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--nav-secondary); margin-bottom: 16px; }
        .carousel-info p { color: #666; line-height: 1.8; margin-bottom: 24px; }
        .tech-list { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 32px; }
        .tech-item { padding: 6px 14px; background: var(--nav-light); border: 1px solid rgba(139,90,43,0.1); border-radius: 8px; font-size: 0.85rem; color: var(--nav-dark); font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; }
        .carousel-nav { display: flex; justify-content: center; gap: 16px; margin-top: 32px; }
        .carousel-btn { width: 56px; height: 56px; border-radius: 50%; border: 2px solid rgba(139,90,43,0.15); background: white; color: var(--nav-primary); font-size: 1.2rem; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; }
        .carousel-btn:hover { background: var(--nav-primary); color: white; border-color: var(--nav-primary); transform: scale(1.1); }
        .carousel-dots { display: flex; gap: 8px; align-items: center; }
        .carousel-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(139,90,43,0.2); border: none; cursor: pointer; transition: all 0.3s ease; }
        .carousel-dot.active { width: 32px; border-radius: 5px; background: var(--nav-primary); }
        @media (max-width: 768px) { .carousel-card { grid-template-columns: 1fr; } .carousel-visual { min-height: 200px; } .carousel-info { padding: 32px; } }

        /* Modal */
        .modal-overlay { position: fixed; inset: 0; background: rgba(26, 21, 18, 0.95); backdrop-filter: blur(20px); z-index: 9998; opacity: 0; visibility: hidden; transition: all 0.4s ease; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .modal-overlay.active { opacity: 1; visibility: visible; }
        .modal-content { background: white; border-radius: 32px; max-width: 800px; width: 100%; max-height: 90vh; overflow-y: auto; transform: translateY(40px) scale(0.95); transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); position: relative; }
        .modal-overlay.active .modal-content { transform: translateY(0) scale(1); }
        .modal-header { padding: 40px 40px 0; position: relative; }
        .modal-close { position: absolute; top: 20px; right: 20px; width: 48px; height: 48px; border-radius: 50%; border: 1px solid rgba(139,90,43,0.15); background: white; color: var(--nav-dark); font-size: 1.2rem; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; z-index: 10; }
        .modal-close:hover { background: var(--nav-primary); color: white; transform: rotate(90deg); }
        .modal-body { padding: 32px 40px 40px; }
        .modal-body h2 { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--nav-secondary); margin-bottom: 16px; }
        .modal-body p { color: #555; line-height: 1.8; margin-bottom: 24px; }
        .modal-meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px; }
        .modal-meta-item { padding: 16px; background: var(--nav-light); border-radius: 16px; border: 1px solid rgba(139,90,43,0.08); }
        .modal-meta-item label { font-size: 0.8rem; color: #999; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; display: block; }
        .modal-meta-item span { font-weight: 600; color: var(--nav-secondary); font-size: 0.95rem; }
        .modal-links { display: flex; gap: 12px; flex-wrap: wrap; }
        .modal-link { padding: 12px 24px; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 8px; }
        .modal-link.primary { background: linear-gradient(135deg, var(--nav-primary), #A67C52); color: white; box-shadow: 0 4px 15px rgba(139,90,43,0.3); }
        .modal-link.primary:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(139,90,43,0.4); }
        .modal-link.secondary { background: white; color: var(--nav-dark); border: 2px solid rgba(139,90,43,0.15); }
        .modal-link.secondary:hover { border-color: var(--nav-primary); color: var(--nav-primary); }

        /* Pie Menu */
        .pie-menu-container { position: fixed; bottom: 32px; right: 32px; z-index: 9990; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .pie-menu-container.active { bottom: 100px; right: 100px; }
        .pie-trigger { width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, var(--nav-primary), var(--nav-accent)); color: white; border: none; font-size: 1.5rem; cursor: pointer; box-shadow: 0 8px 30px rgba(139, 90, 43, 0.4); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; }
        .pie-trigger:hover { transform: scale(1.1); box-shadow: 0 12px 40px rgba(139, 90, 43, 0.5); }
        .pie-trigger.active { transform: rotate(45deg); }
