        @media (max-width: 480px) {
            .footer-grid { grid-template-columns: 1fr; }
            .map-section { padding: 60px 16px; }
            .contact-section { padding: 60px 16px; }
        }

        /* ===== PIE MENU ===== */
        .pie-menu-container {
            position: fixed;
            bottom: 32px;
            right: 32px;
            z-index: 9990;
        }

        .pie-trigger {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--nav-primary), var(--nav-accent));
            color: white;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 8px 30px rgba(139, 90, 43, 0.4);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pie-trigger:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 40px rgba(139, 90, 43, 0.5);
        }

        .pie-trigger.active {
            transform: rotate(45deg);
        }

        .pie-item {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 50px;
            height: 50px;
            margin: -25px 0 0 -25px;
            border-radius: 50%;
            background: white;
            color: var(--nav-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border: 2px solid rgba(139,90,43,0.1);
            cursor: pointer;
            text-decoration: none;
            opacity: 0;
            transform: scale(0.5);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 1;
        }

        .pie-item:hover {
            background: var(--nav-primary);
            color: white;
            transform: scale(1.15);
        }

        .pie-menu-container.active .pie-item {
            opacity: 1;
            transform: scale(1);
        }

        .pie-menu-container.active .pie-item:nth-child(2) { transform: translate(-80px, -60px); }
        .pie-menu-container.active .pie-item:nth-child(3) { transform: translate(-100px, 0px); }
        .pie-menu-container.active .pie-item:nth-child(4) { transform: translate(-80px, 60px); }
        .pie-menu-container.active .pie-item:nth-child(5) { transform: translate(-20px, 90px); }
        .pie-menu-container.active .pie-item:nth-child(6) { transform: translate(50px, 80px); }

        /* Tooltip */
        .custom-tooltip {
            position: fixed;
            padding: 8px 16px;
            background: var(--nav-secondary);
            color: white;
            font-size: 0.85rem;
            font-weight: 500;
            border-radius: 10px;
            pointer-events: none;
            opacity: 0;
            transform: translateY(8px);
            transition: all 0.3s ease;
            z-index: 99999;
            white-space: nowrap;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .custom-tooltip::before {
            content: '';
            position: absolute;
            bottom: -6px;
            left: 50%;
            transform: translateX(-50%);
            border-left: 6px solid transparent;
            border-right: 6px solid transparent;
            border-top: 6px solid var(--nav-secondary);
        }

        .custom-tooltip.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Reveal Animation */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: var(--nav-light);
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, var(--nav-primary), var(--nav-accent));
            border-radius: 5px;
        }

        /* ===== CEO STICKY NOTE ===== */
        .ceo-sticky-note {
            position: relative;
            display: inline-block;
            margin-top: 0;
            background: linear-gradient(135deg, #fffdf5 0%, #fdf6e3 100%);
            padding: 28px 32px;
            border-radius: 4px 24px 24px 24px;
            box-shadow: 
                0 10px 40px rgba(139, 90, 43, 0.15),
                0 2px 8px rgba(0,0,0,0.08),
                inset 0 1px 0 rgba(255,255,255,0.8);
            max-width: 320px;
            transform: rotate(-2deg);
            animation: stickyFloat 6s ease-in-out infinite, stickyFadeIn 1s ease-out 0.8s both;
            border: 1px solid rgba(212, 175, 142, 0.3);
            backdrop-filter: blur(10px);
            flex-shrink: 0;
        }

        /* Scotch tape effect */
        .sticky-tape {
            position: absolute;
            top: -12px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 28px;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,255,255,0.5);
            border-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .sticky-tape::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, 
                transparent 0%, 
                rgba(255,255,255,0.4) 20%, 
                rgba(255,255,255,0.1) 50%, 
                rgba(255,255,255,0.4) 80%, 
                transparent 100%
            );
            border-radius: 4px;
        }

        .sticky-content {
            text-align: center;
            position: relative;
        }

        .sticky-content i {
            font-size: 1.5rem;
            color: var(--nav-primary);
            margin-bottom: 12px;
            display: block;
            animation: iconPulse 3s ease-in-out infinite;
        }

        .sticky-content p {
            font-family: 'Playfair Display', serif;
            font-size: 1.15rem;
            color: var(--nav-secondary);
            margin-bottom: 6px;
            line-height: 1.4;
            font-weight: 700;
        }

        .sticky-content span {
            font-size: 0.85rem;
            color: #8a7e72;
            line-height: 1.5;
            display: block;
        }

        /* Corner fold effect */
        .ceo-sticky-note::after {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, transparent 50%, rgba(139,90,43,0.08) 50%);
            border-radius: 0 0 24px 0;
            box-shadow: -2px -2px 4px rgba(0,0,0,0.03);
        }

        /* Sticky note animations */
        @keyframes stickyFloat {
            0%, 100% { transform: rotate(-2deg) translateY(0); }
            50% { transform: rotate(-1deg) translateY(-8px); }
        }

        @keyframes stickyFadeIn {
            from { opacity: 0; transform: rotate(-5deg) translateY(20px) scale(0.9); }
            to { opacity: 1; transform: rotate(-2deg) translateY(0) scale(1); }
        }

        @keyframes iconPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.15); opacity: 0.8; }
        }

        /* Responsive sticky note and hero */
        @media (max-width: 1024px) {
            .hero-content {
                flex-direction: column;
                gap: 40px;
            }
            .ceo-sticky-note {
                max-width: 280px;
                padding: 22px 24px;
            }
        }
        
        @media (max-width: 768px) {
            .ceo-sticky-note {
                max-width: 280px;
                padding: 22px 24px;
                margin-top: 0;
            }
            .sticky-content p {
                font-size: 1rem;
            }
        }
    </style>
</head>
