    <!-- ==================== JAVASCRIPT ==================== -->
    <script>
        // Mobile menu
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        }

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 50) {
                nav.classList.add('shadow-md');
            } else {
                nav.classList.remove('shadow-md');
            }
        });

        // Pie Menu
        function togglePie() {
            document.getElementById('pie-menu').classList.toggle('active');
        }

        // Chat Bot
        function toggleChat() {
            document.getElementById('chat-window').classList.toggle('closed');
        }
        function openChat() {
            document.getElementById('chat-window').classList.remove('closed');
        }

        function addMessage(text, sender) {
            const container = document.getElementById('chat-messages');
            const div = document.createElement('div');
            div.className = `chat-bubble ${sender}`;
            div.textContent = text;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        function quickChat(text) {
            addMessage(text, 'user');
            setTimeout(() => botReply(text), 600);
        }

        function sendChat() {
            const input = document.getElementById('chat-input');
            const text = input.value.trim();
            if (!text) return;
            addMessage(text, 'user');
            input.value = '';
            setTimeout(() => botReply(text), 800);
        }

        function botReply(userText) {
            const lower = userText.toLowerCase();
            let reply = "I'm here to help! For detailed assistance, you can also call us on +44 (0)333 577 2559 or email sales@bakerdays.com.";
            
            if (lower.includes('flavour') || lower.includes('flavor') || lower.includes('taste')) {
                reply = "We offer Victoria Sponge, Rich Chocolate, Lemon Drizzle, Red Velvet, Carrot, and Coffee & Walnut! We also have gluten-free and vegan options. 🍰";
            } else if (lower.includes('deliver') || lower.includes('post') || lower.includes('ship')) {
                reply = "We deliver next day across the UK if you order by 2pm! We also deliver to BFPO addresses. 🚚";
            } else if (lower.includes('gluten') || lower.includes('vegan') || lower.includes('dairy') || lower.includes('free')) {
                reply = "Yes! We have gluten-free, wheat-free, dairy-free and vegan cakes. Just filter by dietary requirements on any category page. 🌱";
            } else if (lower.includes('price') || lower.includes('cost') || lower.includes('how much')) {
                reply = "Our letterbox cakes start from £12, standard cakes from £19.99, and brownies from £14.99. Personalisation is included! 💰";
            } else if (lower.includes('photo') || lower.includes('picture') || lower.includes('upload')) {
                reply = "You can upload any photo and we'll print it on your cake using edible ink! Just choose a 'Photo Upload' design. 📸";
            } else if (lower.includes('hello') || lower.includes('hi') || lower.includes('hey')) {
                reply = "Hello! Welcome to bakerdays. How can I help make your celebration special today? 🎉";
            }
            
            addMessage(reply, 'bot');
        }

        // Carousel
        function scrollCarousel(direction) {
            const container = document.getElementById('carousel');
            const scrollAmount = 320;
            container.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
        }

        // Overlay Modal
        function openOverlay(title = 'Custom Cake') {
            const modal = document.getElementById('overlay-modal');
            const content = document.getElementById('overlay-content');
            document.getElementById('overlay-title').textContent = title;
            document.getElementById('overlay-desc').textContent = `Personalise your ${title} with a name, message, or photo. Choose from our delicious range of recipes and sizes.`;
            modal.classList.remove('hidden');
            setTimeout(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeOverlay() {
            const modal = document.getElementById('overlay-modal');
            const content = document.getElementById('overlay-content');
            content.classList.remove('scale-100', 'opacity-100');
            content.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }

        // Close overlay on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeOverlay();
        });
    </script>

    <!-- ==================== THREE.JS 3D CAKE ==================== -->
    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // Global material references for UI controls
        window.spongeMat = null;
        window.icingMat = null;
        window.cherryMesh = null;
        window.candleMesh = null;
        window.flameMesh = null;
        window.sprinklesGroup = null;

        function createCakeScene(containerId, autoRotate = true) {
            const container = document.getElementById(containerId);
            const width = container.clientWidth;
            const height = container.clientHeight;

            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0xfffaf5);

            const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 100);
            camera.position.set(7, 5, 7);

            const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(width, height);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            container.appendChild(renderer.domElement);

            const controls = new OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.autoRotate = autoRotate;
            controls.autoRotateSpeed = 2.0;
            controls.minDistance = 5;
            controls.maxDistance = 15;

            // Lighting
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);

            const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
            dirLight.position.set(5, 10, 7);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.width = 2048;
            dirLight.shadow.mapSize.height = 2048;
            scene.add(dirLight);

            const fillLight = new THREE.DirectionalLight(0xffd1b3, 0.5);
            fillLight.position.set(-5, 0, -5);
            scene.add(fillLight);

            // Cake Group
            const cakeGroup = new THREE.Group();
            scene.add(cakeGroup);

            // Plate
            const plateGeo = new THREE.CylinderGeometry(4.2, 4.2, 0.2, 64);
            const plateMat = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.2, metalness: 0.1 });
            const plate = new THREE.Mesh(plateGeo, plateMat);
            plate.position.y = -0.1;
            plate.receiveShadow = true;
            cakeGroup.add(plate);

            // Materials
            const spongeMaterial = new THREE.MeshStandardMaterial({ color: 0xf5deb3, roughness: 0.9 });
            const icingMaterial = new THREE.MeshStandardMaterial({ color: 0xffb7c5, roughness: 0.4, metalness: 0.05 });
            window.spongeMat = spongeMaterial;
            window.icingMat = icingMaterial;

            // Tier 1 (Bottom)
            const t1 = new THREE.Mesh(new THREE.CylinderGeometry(3, 3, 1.5, 64), spongeMaterial);
            t1.position.y = 0.75;
            t1.castShadow = true;
            t1.receiveShadow = true;
            cakeGroup.add(t1);

            // Drip Icing 1
            const i1 = new THREE.Mesh(new THREE.CylinderGeometry(3.15, 3.15, 0.35, 64), icingMaterial);
            i1.position.y = 1.58;
            i1.castShadow = true;
            cakeGroup.add(i1);

            // Tier 2
            const t2 = new THREE.Mesh(new THREE.CylinderGeometry(2.2, 2.2, 1.2, 64), spongeMaterial);
            t2.position.y = 1.8;
            t2.castShadow = true;
            cakeGroup.add(t2);

            const i2 = new THREE.Mesh(new THREE.CylinderGeometry(2.3, 2.3, 0.25, 64), icingMaterial);
            i2.position.y = 2.45;
            i2.castShadow = true;
            cakeGroup.add(i2);

            // Tier 3
            const t3 = new THREE.Mesh(new THREE.CylinderGeometry(1.5, 1.5, 1, 64), spongeMaterial);
            t3.position.y = 2.7;
            t3.castShadow = true;
            cakeGroup.add(t3);

            const i3 = new THREE.Mesh(new THREE.CylinderGeometry(1.6, 1.6, 0.2, 64), icingMaterial);
            i3.position.y = 3.2;
            i3.castShadow = true;
            cakeGroup.add(i3);

            // Cherry
            const cherryMat = new THREE.MeshStandardMaterial({ color: 0xdc143c, roughness: 0.2, metalness: 0.3 });
            const cherry = new THREE.Mesh(new THREE.SphereGeometry(0.35, 32, 32), cherryMat);
            cherry.position.y = 3.5;
            cherry.castShadow = true;
            cakeGroup.add(cherry);
            window.cherryMesh = cherry;

            // Candle
            const candleMat = new THREE.MeshStandardMaterial({ color: 0x87ceeb, emissive: 0x112244 });
            const candle = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 0.8, 16), candleMat);
            candle.position.set(0.6, 3.6, 0.4);
            candle.castShadow = true;
            cakeGroup.add(candle);
            window.candleMesh = candle;

            // Flame
            const flameMat = new THREE.MeshBasicMaterial({ color: 0xffa500 });
            const flame = new THREE.Mesh(new THREE.SphereGeometry(0.12, 16, 16), flameMat);
            flame.position.set(0.6, 4.05, 0.4);
            cakeGroup.add(flame);
            window.flameMesh = flame;

            // Sprinkles (hidden by default)
            const sprinkles = new THREE.Group();
            const sprinkleGeo = new THREE.CapsuleGeometry(0.04, 0.12, 4, 8);
            const colors = [0xff0000, 0x00ff00, 0x0000ff, 0xffff00, 0xff00ff];
            for (let i = 0; i < 40; i++) {
                const mat = new THREE.MeshStandardMaterial({ color: colors[Math.floor(Math.random() * colors.length)] });
                const mesh = new THREE.Mesh(sprinkleGeo, mat);
                const angle = Math.random() * Math.PI * 2;
                const radius = Math.random() * 2.8;
                mesh.position.set(Math.cos(angle) * radius, 1.75 + Math.random() * 1.5, Math.sin(angle) * radius);
                mesh.rotation.set(Math.random(), Math.random(), Math.random());
                sprinkles.add(mesh);
            }
            sprinkles.visible = false;
            cakeGroup.add(sprinkles);
            window.sprinklesGroup = sprinkles;

            // Animation loop
            function animate() {
                requestAnimationFrame(animate);
                controls.update();
                
                // Flicker flame
                if (window.flameMesh) {
                    const time = Date.now() * 0.01;
                    window.flameMesh.scale.y = 1 + Math.sin(time) * 0.2;
                    window.flameMesh.position.y = 4.05 + Math.sin(time * 2) * 0.02;
                }
                
                renderer.render(scene, camera);
            }
            animate();

            // Resize handler
            window.addEventListener('resize', () => {
                const w = container.clientWidth;
                const h = container.clientHeight;
                camera.aspect = w / h;
                camera.updateProjectionMatrix();
                renderer.setSize(w, h);
            });

            return { scene, camera, renderer };
        }

        // Initialize Hero Canvas (simpler view)
        createCakeScene('hero-canvas', true);
        document.getElementById('hero-loader').style.display = 'none';

        // Initialize Studio Canvas
        createCakeScene('cake-studio-canvas', false);

        // UI Control Functions
        window.changeSponge = (color) => {
            if (window.spongeMat) window.spongeMat.color.set(color);
        };
        window.changeIcing = (color) => {
            if (window.icingMat) window.icingMat.color.set(color);
        };
        window.toggleDecor = (type, visible) => {
            if (type === 'cherry' && window.cherryMesh) window.cherryMesh.visible = visible;
            if (type === 'candle' && window.candleMesh) {
                window.candleMesh.visible = visible;
                if (window.flameMesh) window.flameMesh.visible = visible;
            }
            if (type === 'sprinkles' && window.sprinklesGroup) window.sprinklesGroup.visible = visible;
        };
    </script>
</body>
</html>